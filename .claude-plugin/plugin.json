{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "gitlab-mr-guardian",
  "displayName": "GitLab MR Guardian",
  "version": "0.6.0",
  "description": "Monitors approved GitLab merge requests, safely rebases stale branches, enables auto-merge, and reports CI failures.",
  "author": {
    "name": "MisterRaindrop"
  },
  "homepage": "https://github.com/MisterRaindrop/gitlab-mr-guardian",
  "repository": "https://github.com/MisterRaindrop/gitlab-mr-guardian",
  "license": "Apache-2.0",
  "keywords": [
    "gitlab",
    "merge-request",
    "ci",
    "monitor"
  ],
  "experimental": {
    "monitors": "./monitors/monitors.json"
  }
}
